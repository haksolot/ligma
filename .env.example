# --- DISCORD CONFIGURATION ---
# Your Discord Bot Token (from Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Your Discord User ID (to allow access to admin commands like /model, /personality, etc.)
CREATOR_ID=000000000000000000

# --- OLLAMA CONFIGURATION ---
# The default model to use (must be pulled in Ollama first: e.g., 'ollama pull llama3.2:3b')
DEFAULT_MODEL=llama3.2:3b

# --- CORE SETTINGS ---
# Number of messages to keep in short-term memory before summarizing
MEMORY_LIMIT=6

# --- GIFS CONFIGURATION (GIPHY) ---
# Your Giphy API Key (from Giphy Developers Portal)
GIPHY_API_KEY=your_giphy_api_key_here
