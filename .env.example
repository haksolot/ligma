# --- DISCORD CONFIGURATION ---
# Your Discord Bot Token (from Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Your Discord User ID (to allow access to admin commands like /model, /personality, etc.)
CREATOR_ID=000000000000000000

# --- LLM PROVIDER CONFIGURATION ---
# Provider: "ollama" (local) or "openrouter" (cloud via OpenRouter)
LLM_PROVIDER=ollama

# Default model name
# For Ollama: must be pulled locally (e.g., 'ollama pull llama3.2:3b')
# For OpenRouter: use the OpenRouter model ID (e.g., 'openai/gpt-4o', 'anthropic/claude-3.5-sonnet', 'google/gemini-2.0-flash')
DEFAULT_MODEL=llama3.2:3b

# OpenRouter API Key (only needed if LLM_PROVIDER=openrouter)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- CORE SETTINGS ---
# Number of messages to keep in short-term memory before summarizing
MEMORY_LIMIT=6

# --- GIFS CONFIGURATION (GIPHY) ---
# Your Giphy API Key (from Giphy Developers Portal)
GIPHY_API_KEY=your_giphy_api_key_here
